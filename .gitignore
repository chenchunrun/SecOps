# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# Local Go caches (optional test/build overrides)
.gocache/
.gomodcache/

# IDE specific files
.idea/
.vscode/
*.swp
*.swo

# Python bytecode (bundled skills may run scripts locally)
**/__pycache__/
*.py[cod]

# OS specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.log

# Binary output directory
/bin/
/dist/

# Local environment variables
.env
.env.local

**/.crush/**

/crush
/tmp/

manpages/
completions/crush.*sh
.prettierignore
.task

# Compiled binary (anchored to repo root: a bare "SecOps" would also match the
# case-insensitive secops/ source directory on macOS, hiding new files there)
/SecOps
/crush

# SecOps internal development docs (keep local only)
/SECOPS_DOD_MATRIX.md
/SECOPS_FEATURES.md
/SECOPS_PROJECT_PLAN.md
/SECURITY_HARDENING.md
/LOCAL_*
/WINDOWS_TEST_STABILITY_GUIDE_*.md
/CLAUDE.md
/SecOps-macos-test
/docs/project/
/docs/release/
/docs/security/
/docs/SECOPS_E2E_TEST_PLAN.md
